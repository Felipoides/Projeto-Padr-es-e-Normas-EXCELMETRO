# ============================================================================
#  MetroControl — exemplo de variáveis de ambiente
#  Copie para ".env" e ajuste. O servidor lê estas variáveis do ambiente.
#  (Em Render/Railway/Fly, defina-as no painel do serviço.)
# ============================================================================

# Porta HTTP (a nuvem geralmente injeta automaticamente)
PORT=3000

# Segredo de assinatura dos tokens JWT — OBRIGATÓRIO trocar em produção!
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-este-valor-por-um-segredo-longo-e-aleatorio

# Caminho do arquivo SQLite (use um volume persistente na nuvem)
DB_PATH=./data/metrocontrol.db

# String de conexão PostgreSQL (apenas se migrar — ver docs/HOSPEDAGEM.md)
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# Origem permitida para CORS (restrinja em produção)
CORS_ORIGIN=*
